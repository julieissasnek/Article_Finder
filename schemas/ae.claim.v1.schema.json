{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/ae.claim.v1.schema.json",
  "schema_id": "ae.claim.v1",
  "title": "AE Claim Record (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "claim_id",
    "paper_id",
    "claim_type",
    "statement",
    "constructs",
    "study",
    "statistics",
    "evidence",
    "constraints",
    "ae_confidence"
  ],
  "properties": {
    "schema": {
      "const": "ae.claim.v1"
    },
    "claim_id": {
      "type": "string"
    },
    "paper_id": {
      "type": "string"
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "causal",
        "associational",
        "null",
        "moderated",
        "mechanistic",
        "descriptive"
      ]
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "constructs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_factors",
        "outcomes",
        "mediators",
        "moderators"
      ],
      "properties": {
        "environment_factors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/construct_item"
          }
        },
        "outcomes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/construct_item"
          }
        },
        "mediators": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/construct_item"
          }
        },
        "moderators": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moderator_item"
          }
        }
      }
    },
    "study": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "design",
        "sample",
        "task",
        "setting"
      ],
      "properties": {
        "design": {
          "type": "string"
        },
        "sample": {
          "$ref": "#/$defs/sample"
        },
        "task": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task_item"
          }
        },
        "setting": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/setting_item"
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect_size",
        "p_value",
        "ci95"
      ],
      "properties": {
        "effect_size": {
          "$ref": "#/$defs/effect_size"
        },
        "p_value": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.0,
          "maximum": 1.0
        },
        "ci95": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ae_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    }
  },
  "$defs": {
    "construct_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "direction": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "moderator_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "value"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "value": {
          "type": [
            "string",
            "number",
            "null"
          ]
        }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "n",
        "population",
        "age_mean",
        "country"
      ],
      "properties": {
        "n": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "population": {
          "type": [
            "string",
            "null"
          ]
        },
        "age_mean": {
          "type": [
            "number",
            "null"
          ]
        },
        "country": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "task_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "setting_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "effect_size": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "span",
            "table_cell",
            "figure_ref",
            "manual_note"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "start": {
          "type": [
            "integer",
            "null"
          ]
        },
        "end": {
          "type": [
            "integer",
            "null"
          ]
        },
        "table_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "row": {
          "type": [
            "integer",
            "null"
          ]
        },
        "col": {
          "type": [
            "string",
            "null"
          ]
        },
        "figure_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}