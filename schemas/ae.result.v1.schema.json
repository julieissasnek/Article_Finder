{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/ae.result.v1.schema.json",
  "schema_id": "ae.result.v1",
  "title": "AE Result Output (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "paper_id",
    "pdf_sha256",
    "run_id",
    "status",
    "profile",
    "hitl",
    "summary",
    "artifacts",
    "quality",
    "errors"
  ],
  "properties": {
    "schema": {
      "const": "ae.result.v1"
    },
    "paper_id": {
      "type": "string"
    },
    "pdf_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "PARTIAL_SUCCESS",
        "FAIL"
      ]
    },
    "profile": {
      "type": "string",
      "enum": [
        "fast",
        "standard",
        "deep"
      ]
    },
    "hitl": {
      "type": "string",
      "enum": [
        "off",
        "auto",
        "required"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "n_claims",
        "n_rules",
        "n_effect_sizes",
        "n_population_records",
        "n_environment_factors"
      ],
      "properties": {
        "n_claims": {
          "type": "integer",
          "minimum": 0
        },
        "n_rules": {
          "type": "integer",
          "minimum": 0
        },
        "n_effect_sizes": {
          "type": "integer",
          "minimum": 0
        },
        "n_population_records": {
          "type": "integer",
          "minimum": 0
        },
        "n_environment_factors": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claims_jsonl",
        "rules_jsonl",
        "provenance_json",
        "audit_log_jsonl"
      ],
      "properties": {
        "claims_jsonl": {
          "type": "string"
        },
        "rules_jsonl": {
          "type": "string"
        },
        "provenance_json": {
          "type": "string"
        },
        "audit_log_jsonl": {
          "type": "string"
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence",
        "blocking_issues",
        "warnings"
      ],
      "properties": {
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "blocking_issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}