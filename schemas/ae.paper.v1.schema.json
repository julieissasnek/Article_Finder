{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/ae.paper.v1.schema.json",
  "schema_id": "ae.paper.v1",
  "title": "AE Paper Input (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "paper_id",
    "title",
    "authors",
    "year",
    "source",
    "files"
  ],
  "properties": {
    "schema": {
      "const": "ae.paper.v1"
    },
    "paper_id": {
      "type": "string",
      "minLength": 3
    },
    "doi": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "orcid": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "year": {
      "type": "integer",
      "minimum": 1500,
      "maximum": 3000
    },
    "venue": {
      "type": [
        "string",
        "null"
      ]
    },
    "publisher": {
      "type": [
        "string",
        "null"
      ]
    },
    "url": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finder_run_id",
        "ingest_method",
        "retrieved_at"
      ],
      "properties": {
        "finder_run_id": {
          "type": "string"
        },
        "ingest_method": {
          "type": "string"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "triage": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "score",
        "decision",
        "reasons"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "decision": {
          "type": "string"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pdf_sha256",
        "pdf_bytes"
      ],
      "properties": {
        "pdf_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "pdf_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "rights": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "license",
        "allowed_storage"
      ],
      "properties": {
        "license": {
          "type": [
            "string",
            "null"
          ]
        },
        "allowed_storage": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "human_notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}